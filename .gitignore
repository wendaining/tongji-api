# Profiling output.
*.prof
*.pstats
profile/
profiling/

# Jupyter / IPython.
.ipynb_checkpoints/
profile_default/
ipython_config.py

# PyInstaller.
*.manifest
*.spec

# Celery / multiprocessing / local queues.
celerybeat-schedule
celerybeat.pid
*.db-shm
*.db-wal

# SQLite and other local database files. Keep migrations and schemas committed.
*.sqlite
*.sqlite3
*.db

