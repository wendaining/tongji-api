# ---------------------------------------------------------------------------
# one-dot-tongji-api local secrets and runtime state
# ---------------------------------------------------------------------------

# Environment files may contain TJ_API_TOKEN, TJ_SESSIONID, proxy settings, or
# future IAM credentials. Keep examples committed as .env.example.
.env
.env.*
!.env.example
!.env.*.example
.envrc
.envrc.*
!.envrc.example
.direnv/
.dev.vars
.dev.vars.*
!.dev.vars.example
.local/

# Persisted 1.tongji.edu.cn login state and local runtime data.
data/*
!data/.gitkeep
*.session
*.session.json
session.json
cookies.json
cookiejar
cookiejar.*
*.cookie
*.cookies

# Local secrets and credentials.
secrets/
secret/
credentials/
private/
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.kdbx
*.asc
*.gpg
*.age
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
known_hosts

# Logs can accidentally include request metadata. The application should still
# redact tokens, but logs do not belong in git.
logs/
log/
*.log
*.log.*
*.out
*.err
*.pid
*.pid.lock

# Local scratch files for manual raw-one experiments.
scratch/
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp
*.bak
*.backup
*.orig

