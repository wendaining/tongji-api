npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.yarn/
.pnpm-store/
.turbo/
.next/
.nuxt/
.svelte-kit/
.vite/
vite.config.*.timestamp-*
vite.config.*.mjs-*

# Keep lock files trackable:
#   package-lock.json
#   npm-shrinkwrap.json
#   yarn.lock
#   pnpm-lock.yaml

